# ============================================================
# Terraform working directories
# ============================================================
# Terraform downloads providers and modules into this directory.
# It can be recreated by running "terraform init".
**/.terraform/


# ============================================================
# Terraform state files
# ============================================================
# State files record details about managed infrastructure.
# They may contain IP addresses, paths, IDs, and sensitive values.
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info


# ============================================================
# Terraform plan files
# ============================================================
# Saved plans are generated by commands such as:
# terraform plan -out=project.tfplan
*.tfplan
*.plan


# ============================================================
# Local variable files
# ============================================================
# These files may contain local paths, usernames, passwords,
# tokens, keys, or environment-specific values.
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Keep example variable files in Git.
!terraform.tfvars.example
!*.tfvars.example


# ============================================================
# Terraform override files
# ============================================================
# Override files are normally used for temporary local changes.
override.tf
override.tf.json
*_override.tf
*_override.tf.json


# ============================================================
# Terraform crash and log files
# ============================================================
crash.log
crash.*.log
*.log


# ============================================================
# Sensitive keys and certificates
# ============================================================
# Never commit private SSH keys, private certificates, or secrets.
*.pem
*.key
*.p12
*.pfx
*.crt
*.csr

# Common SSH private-key filenames
id_rsa
id_ed25519
id_ecdsa
id_dsa

# Environment-variable and secret files
.env
.env.*
*.secret
secrets.yaml
secrets.yml


# ============================================================
# Virtual-machine and disk images
# ============================================================
# Prevent large VM images from being accidentally committed.
*.qcow2
*.raw
*.vmdk
*.vdi
*.iso
*.img


# ============================================================
# Generated cloud-init files
# ============================================================
# Ignore generated cloud-init output, but not source templates.
cloud-init-output/
generated/
*.seed.iso
*-seed.iso


# ============================================================
# Ansible temporary and sensitive files
# ============================================================
*.retry
.vault_pass
vault-password-file
ansible-vault-password


# ============================================================
# Kubernetes sensitive configuration
# ============================================================
# kubeconfig files can contain cluster credentials.
kubeconfig
kubeconfig.*
admin.conf

# Kubernetes secrets rendered locally
*-secret.yaml
*-secret.yml


# ============================================================
# Editor and IDE files
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store


# ============================================================
# Operating-system temporary files
# ============================================================
Thumbs.db
desktop.ini
